# Supabase client configuration for the Expo/iOS app.
# EXPO_PUBLIC_* values are bundled into the app by Rork/Expo.
# Use the public publishable/anon key only. Never use a service role key here.
EXPO_PUBLIC_SUPABASE_URL=https://cgcrkwlexwtrvlliavgn.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace_with_supabase_publishable_or_anon_key

# Optional private aliases for local scripts/tools. These are not enough for iOS bundling.
SUPABASE_URL=https://cgcrkwlexwtrvlliavgn.supabase.co
SUPABASE_ANON_KEY=replace_with_supabase_publishable_or_anon_key
